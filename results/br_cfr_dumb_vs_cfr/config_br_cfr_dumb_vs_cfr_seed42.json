    "tilt_enabled": true,
    "tilt_loss_streak_k": 3,
    "tilt_shock_payoff": -8.0,
    "tilt_duration_hands": 4,
    "tilt_tau_multiplier": 2.0,
    "tilt_min_soft_tau": 1.5,
